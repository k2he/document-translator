# ── Provider ─────────────────────────────────────────────────────────────────
# Options: openai | ollama
TRANSLATION_PROVIDER=openai

# ── OpenAI (used when TRANSLATION_PROVIDER=openai) ───────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Ollama (used when TRANSLATION_PROVIDER=ollama) ───────────────────────────
# Recommended model for Chinese→English academic translation: qwen2.5:72b
# Lower VRAM alternatives: qwen2.5:32b (good), qwen2.5:14b (fast)
# Run: ollama pull qwen2.5:72b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:72b

# ── Shared ───────────────────────────────────────────────────────────────────
INPUT_DIR=input
OUTPUT_DIR=output
