# ── Provider ─────────────────────────────────────────────────────────────────
# Options: openai | ollama
TRANSLATION_PROVIDER=openai

# ── OpenAI (used when TRANSLATION_PROVIDER=openai) ───────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ── Ollama (used when TRANSLATION_PROVIDER=ollama) ───────────────────────────
# Recommended model for Chinese→English academic translation: qwen3.6:35b
# Available Qwen3 sizes: 0.6b | 1.7b | 4b | 8b | 14b | 32b | 72b
# Run: ollama pull qwen3.6:35b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.6:35b

# ── Shared ───────────────────────────────────────────────────────────────────
INPUT_DIR=input
OUTPUT_DIR=output
